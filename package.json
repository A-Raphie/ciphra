{
  "name": "fhe-proof-of-reserves",
  "version": "0.1.0",
  "private": true,
  "description": "Confidential solvency proofs on Zama Protocol — FHE Proof-of-Reserves",
  "license": "BSD-3-Clause-Clear",
  "packageManager": "pnpm@11.1.2",
  "scripts": {
    "install:all": "pnpm install",
    "dev": "pnpm --filter frontend dev",
    "build": "pnpm --filter frontend build",
    "lint": "pnpm -r lint",
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm --filter smart-contracts test"
  },
  "engines": {
    "node": ">=20"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "keccak",
      "secp256k1"
    ]
  }
}
